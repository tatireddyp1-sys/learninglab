# =============================================================================
# Learning Lab — API (copy to ".env" in this folder and restart "npm run dev")
# =============================================================================

# --- LMS API base (no trailing slash). Vite also injects this as VITE_LMS_API_BASE_URL when unset below.
LEARNING_LAB_API_BASE_URL=https://ryipt781n1.execute-api.us-east-2.amazonaws.com/v1

# --- Browser: explicit API Gateway base (recommended). Admin module = POST {this}/admin
VITE_LMS_API_BASE_URL=https://ryipt781n1.execute-api.us-east-2.amazonaws.com/v1

# --- Browser override (optional)
# Omit the two URL lines above and rely on LEARNING_LAB_API_BASE_URL only (Vite injects it for the SPA).
# Same-origin proxy via Express (no CORS to AWS from the browser): VITE_LMS_API_BASE_URL=/v1

# Force in-browser mock for auth/admin (ignores live base above)
# VITE_LMS_API_MOCK_AUTH_ADMIN=true

# Force mock for courses + lessons only (auth/admin still live when base URL is set)
# VITE_LMS_API_MOCK_COURSES_LESSONS=true

# Force mock for enrollments only (useful when testing courses/lessons against AWS but enrollments are not deployed)
# VITE_LMS_API_MOCK_ENROLLMENTS=true

# POST …/enrollments unenroll action name (mock supports both): deleteEnrollment | removeEnrollment
# VITE_LMS_ENROLLMENTS_DELETE_ACTION=removeEnrollment

# Progress uses POST …/v1/progress over HTTP when VITE_LMS_API_BASE_URL is set (same as courses/enrollments).

# Force mock for progress only
# VITE_LMS_API_MOCK_PROGRESS=true

# Console: [LearningLab API] HTTP vs MOCK
# VITE_LMS_API_DEBUG=true

# Use a fixed JWT for lessons API only (auth/admin/courses still use login session token)
# VITE_LMS_LESSONS_ACCESS_TOKEN=
