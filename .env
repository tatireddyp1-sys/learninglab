# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# Upstream Learning Lab API Gateway base URL (no trailing slash).
LEARNING_LAB_API_BASE_URL="https://ryipt781n1.execute-api.us-east-2.amazonaws.com/v1"

# Same URL for the SPA — admin calls POST this URL + /admin (see client/lib/learningLabApi.ts).
VITE_LMS_API_BASE_URL=https://ryipt781n1.execute-api.us-east-2.amazonaws.com/v1
 